model Address {
  id         String   @id @default(cuid())
  country    String
  province   String
  city       String
  district   String?
  village    String?
  postalCode String?
  latitude   Float?
  longitude  Float?
  job        Job?
  profile    Profile?
}

model Profile {
  id          String   @id @default(cuid())
  displayName String
  username    String   @unique
  avatar      String?
  headline    String
  bio         String?
  website     String?
  github      String?
  linkedin    String?
  portfolio   String?
  hourlyRate  Int?
  currency    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String   @unique
  addressId   String?  @unique
  job         Job[]
  address     Address? @relation(fields: [addressId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Job {
  id           String          @id @default(cuid())
  company      String
  title        String
  description  String
  banner       String?
  budgetMin    Int?
  budgetMax    Int?
  deadline     DateTime?
  isVerified   Boolean         @default(false)
  isOpen       Boolean         @default(true)
  tags         String[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  locationType JobLocationType
  profileId    String
  addressId    String?         @unique
  address      Address?        @relation(fields: [addressId], references: [id])
  profile      Profile         @relation(fields: [profileId], references: [id])
}

enum JobLocationType {
  ONSITE
  REMOTE
  HYBRID
}
